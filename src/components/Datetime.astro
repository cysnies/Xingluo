---
import dayjs from "@/lib/dayjs";
import Calendar from "@/assets/icons/Calendar.astro";
import config from "@/config";
import { useTranslations } from "@/i18n";
import { tplStr } from "@/i18n";
import { cn } from "@/lib/utils";

interface Props {
  class?: string;
  size?: "sm" | "lg";
  pubDatetime: string | Date;
  timezone?: string;
  modDatetime?: string | Date | null;
}

const {
  pubDatetime,
  modDatetime,
  size = "sm",
  class: className,
  timezone: postTimezone,
} = Astro.props;

const t = useTranslations(Astro.currentLocale);

const pubDate = dayjs(pubDatetime).tz(postTimezone ?? config.site.timezone);
const pubDateStr = pubDate.format("YYYY-MM-DD");

const isModified = modDatetime && dayjs(modDatetime).valueOf() > dayjs(pubDatetime).valueOf();
let modDateStr = "";
let modifiedTime = "";
if (isModified) {
  const modDate = dayjs(modDatetime).tz(postTimezone ?? config.site.timezone);
  modDateStr = modDate.format("YYYY-MM-DD");
  modifiedTime = modDate.toISOString();
}
---

<div
  class={cn(
    "flex items-center gap-x-1.5 text-muted-foreground",
    isModified && "flex-wrap",
    className,
  )}
>
  <Calendar class={cn("size-4 shrink-0", size === "sm" && "scale-90")} />
  <time
    class={cn("text-sm", size === "lg" && "sm:text-base")}
    datetime={pubDate.toISOString()}
  >
    {tplStr(t.post.publishedAt, { date: pubDateStr })}
  </time>
  {isModified && (
    <>
      <span class="text-sm text-muted-foreground/50" aria-hidden="true">·</span>
      <time
        class={cn("text-sm", size === "lg" && "sm:text-base")}
        datetime={modifiedTime}
      >
        {tplStr(t.post.updatedAt, { date: modDateStr })}
      </time>
    </>
  )}
</div>
