---
/**
 * 评论系统统一容器组件
 * 根据 features.comments.provider 渲染对应子组件，provider 为 false 时不输出任何内容
 * 客户端懒加载与主题同步逻辑位于 src/scripts/comments.ts
 */
import config from "@/config";
import { useTranslations, DEFAULT_LOCALE } from "@/i18n";
import Giscus from "./Giscus.astro";
import Twikoo from "./Twikoo.astro";
import Waline from "./Waline.astro";

interface Props {
  /** 当前语言，决定评论系统 UI 语言 */
  locale?: string;
}

const { locale = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(locale);
const commentsConfig = config.features.comments;

// 将站点 locale 映射为各评论系统期望的语言代码
const mapLang = (loc: string): string =>
  loc.toLowerCase() === "zh-cn" ? "zh-CN" : loc;

// 初始主题占位：实际主题由 comments.ts 在客户端根据 html.dark 同步
const initialTheme = "light";
const lang = mapLang(locale);

const provider = commentsConfig.provider;
const showComments = provider !== false;
const giscusConfig = provider === "giscus" ? commentsConfig.giscus : null;
const twikooConfig = provider === "twikoo" ? commentsConfig.twikoo : null;
const walineConfig = provider === "waline" ? commentsConfig.waline : null;
---

{showComments && (
  <section class="xng-comments mt-12" aria-label={t.comments.title}>
    <h2 class="mb-4 text-xl font-semibold">{t.comments.title}</h2>
    <div class="xng-comments-mount" data-provider={provider}>
      {provider === "giscus" && giscusConfig && (
        <Giscus config={giscusConfig} lang={lang} theme={initialTheme} />
      )}
      {provider === "twikoo" && twikooConfig && (
        <Twikoo config={twikooConfig} lang={lang} />
      )}
      {provider === "waline" && walineConfig && (
        <Waline config={walineConfig} lang={lang} />
      )}
    </div>
  </section>

  <script>
    import "@/scripts/comments";
  </script>
)}
