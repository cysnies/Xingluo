---
/**
 * Waline 评论系统组件
 * 仅渲染挂载占位，实际初始化由 comments.ts 在滚动到视口时动态 import @waline/client 完成
 */
import type { WalineConfig } from "@/types/config";

interface Props {
  /** waline 配置（来自站点配置） */
  config: WalineConfig;
  /** 语言代码，如 zh-CN */
  lang: string;
}

const { config: waline, lang } = Astro.props;
const mountId = `xng-waline-${Math.random().toString(36).slice(2, 10)}`;
---

<div
  id={mountId}
  class="xng-waline"
  data-server-url={waline.serverURL}
  data-lang={lang}
  data-page-size={waline.pageSize ?? 10}
></div>
