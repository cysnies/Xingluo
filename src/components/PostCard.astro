---
import type { CollectionEntry } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import { getPostUrl } from "@/utils/getPostPaths";
import { slugifyStr } from "@/utils/slugify";
import { toTransitionName } from "@/utils/toTransitionName";
import { useTranslations, tplStr } from "@/i18n";
import { getReadingTime } from "@/utils/readingTime";
import config from "@/config";
import Datetime from "./Datetime.astro";
import Tag from "./Tag.astro";
import Clock from "@/assets/icons/Clock.astro";
import Card from "@/components/ui/Card.astro";
import CardTitle from "@/components/ui/CardTitle.astro";
import CardDescription from "@/components/ui/CardDescription.astro";
import { cn } from "@/lib/utils";

interface Props {
  post: CollectionEntry<"posts">;
  /** 是否显示标签 */
  showTags?: boolean;
  class?: string;
}

const { post, showTags = true, class: className } = Astro.props;
const { data, id, filePath } = post;
const locale = Astro.currentLocale ?? config.site.lang;
const tr = useTranslations(locale);
const href = getPostUrl(id, filePath, locale);
const tags = data.tags.map((tag) => ({
  tag: slugifyStr(tag),
  tagName: tag,
}));
const transitionName = toTransitionName(data.title);
/** 阅读时长（分钟）：按当前语言的字符/单词速率估算 */
const readingMinutes = getReadingTime(post.body ?? "", locale);
/** 分类链接：设置 category 时生成对应分类页地址 */
const categorySlug = data.category ? slugifyStr(data.category) : undefined;
const categoryHref = categorySlug
  ? getRelativeLocaleUrl(locale, `categories/${categorySlug}/`)
  : undefined;

/**
 * 文章头图地址解析：
 * - image() 对象取 .src（经 Astro 资源管线优化后的带哈希路径）
 * - 字符串直接作为 public/ 路径或外链使用
 * - 未设置时不渲染头图
 * 仅在全局开关 showPostCardHero 开启时才解析与展示
 */
let heroImageSrc: string | undefined;
if (config.features.showPostCardHero) {
  if (typeof data.heroImage === "string") {
    heroImageSrc = data.heroImage;
  } else if (
    data.heroImage &&
    typeof data.heroImage === "object" &&
    "src" in data.heroImage
  ) {
    heroImageSrc = data.heroImage.src;
  }
}
/** 是否展示头图：全局开关开启且文章配置了头图 */
const showHero = !!heroImageSrc;
---

<Card
  class={cn(
    "group relative flex h-[200px] flex-row overflow-hidden transition-colors hover:bg-accent/30",
    className
  )}
>
  {/* 左侧主内容区：标题、信息、描述、分类与标签 */}
  <div class="relative z-10 flex min-w-0 flex-1 flex-col justify-evenly gap-0 py-3">
    {/* 标题行：固定两行高度，超出两行截断，保证跨卡片对齐 */}
    <CardTitle
      transition:name={transitionName}
      class="mx-4 min-h-12 line-clamp-2 leading-snug transition-colors group-hover:text-primary"
    >
      <a href={href} class="after:absolute after:inset-0">{data.title}</a>
    </CardTitle>

    {/* 文章信息行：固定高度，保证跨卡片对齐 */}
    <div class="mx-4 flex min-h-6 items-center gap-x-3">
      <Datetime
        pubDatetime={data.pubDatetime}
        modDatetime={data.modDatetime}
        timezone={data.timezone}
        size="sm"
      />
      <span class="flex items-center gap-x-1 text-muted-foreground">
        <Clock class="size-3.5 shrink-0" />
        <span class="text-sm">
          {tplStr(tr.post.readingTime, { minutes: readingMinutes })}
        </span>
      </span>
    </div>

    {/* 描述行：固定三行高度，保证跨卡片对齐 */}
    {data.description && (
      <CardDescription class="mx-4 min-h-[3.75rem] line-clamp-3">{data.description}</CardDescription>
    )}

    {/* 分类与标签行：单行展示，溢出该行后自动截断；相对定位提升层级，保持独立可点击 */}
    {
      showTags && (tags.length > 0 || categoryHref) && (
        <div class="relative z-10 mx-4 flex min-h-6 items-center gap-2 overflow-hidden whitespace-nowrap">
          {categoryHref && (
            <a
              href={categoryHref}
              class="inline-flex shrink-0 items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary transition-colors hover:bg-primary/20"
            >
              {data.category}
            </a>
          )}
          {tags.map((t) => (
            <Tag tag={t.tag} tagName={t.tagName} size="sm" />
          ))}
        </div>
      )
    }
  </div>

  {/* 头图背景层：全局开关开启且文章配置了头图时，作为卡片背景展示，带有从左到右的透明渐变过渡。
      移动端根据 showPostCardHeroMobile 配置决定是否隐藏，防止头图与文字挤在一起阻碍阅读 */}
  {showHero && (
    <div
      class={cn(
        "pointer-events-none absolute inset-0",
        config.features.showPostCardHeroMobile ? "" : "hidden md:block"
      )}
      style={{
        backgroundImage: `url(${heroImageSrc})`,
        backgroundSize: "cover",
        backgroundPosition: "right center",
        maskImage:
          "linear-gradient(to right, transparent 0%, transparent 40%, black 55%, black 100%)",
        WebkitMaskImage:
          "linear-gradient(to right, transparent 0%, transparent 40%, black 55%, black 100%)",
      }}
    />
  )}
</Card>