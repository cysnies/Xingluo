---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@/lib/utils";

interface Props extends HTMLAttributes<"div"> {
  /** 页面标题 */
  title: string;
  /** 页面描述 */
  description?: string;
  /** 是否显示返回按钮（需配合 slot） */
  class?: string;
}

const { title, description, class: className, ...rest } = Astro.props as Props;
---

<div class={cn("space-y-2", className)} {...rest}>
  <slot name="before" />
  <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
  {description && <p class="text-muted-foreground">{description}</p>}
  <slot />
</div>
