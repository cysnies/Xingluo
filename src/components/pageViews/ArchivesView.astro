---
import { getRelativeLocaleUrl } from "astro:i18n";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import PostCard from "@/components/PostCard.astro";
import { getPostsForLocale } from "@/utils/i18nPosts";
import { groupPostsByYearMonth } from "@/utils/getPostsByGroupCondition";
import { getCardWidth } from "@/utils/getCardWidth";
import { useTranslations, tplStr } from "@/i18n";
import config from "@/config";
import dayjs from "@/lib/dayjs";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
const timezone = config.site.timezone;

// 关闭归档页时重写到 404
const notFoundUrl = getRelativeLocaleUrl(locale, "404");
if (!config.features.showArchives && notFoundUrl) {
  return Astro.rewrite(notFoundUrl);
}

const posts = await getCollection("posts");
const sortedPosts = getPostsForLocale(posts, locale);

// 按年→月两级分组，年月均降序
const yearGroups = groupPostsByYearMonth(sortedPosts, (post) =>
  dayjs(post.data.pubDatetime).tz(timezone).toDate()
);

const title = t.pages.archivesTitle;
const description = t.pages.archivesDesc;
const crumbs = [
  { href: getRelativeLocaleUrl(locale), label: t.nav.home },
  { label: title },
];
---

<Layout title={title} description={description}>
  <Header />
  <Main>
    <Breadcrumb items={crumbs} class="mb-6" />
    <h1 class="mb-6 text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
    <p class="mb-8 text-muted-foreground">{description}</p>

    <div class="space-y-10">
      {
        yearGroups.map((yearGroup) => (
          <section>
            <h2 class="mb-4 flex items-center gap-2 text-2xl font-semibold tracking-tight">
              {yearGroup.year}
              <sup class="text-sm font-normal text-muted-foreground">
                {tplStr(t.archives.postCount, { count: String(yearGroup.posts.length) })}
              </sup>
            </h2>
            <div class="space-y-8">
              {yearGroup.months.map((monthGroup) => (
                <div>
                  <h3 class="mb-3 flex items-center gap-2 text-lg font-medium">
                    {tplStr(t.archives.monthLabel, { month: String(monthGroup.month) })}
                    <sup class="text-xs font-normal text-muted-foreground">
                      {tplStr(t.archives.postCount, { count: String(monthGroup.posts.length) })}
                    </sup>
                  </h3>
                  <ul class="grid grid-cols-1 items-start gap-4 md:grid-cols-2">
                    {monthGroup.posts.map((post) => {
                      const width = getCardWidth(post, config.features.showPostCardHero);
                      return (
                        <li class={width === "full" ? "col-span-1 md:col-span-2" : "col-span-1"}>
                          <PostCard post={post} />
                        </li>
                      );
                    })}
                  </ul>
                </div>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </Main>
  <Footer />
</Layout>
