---
import { type CollectionEntry } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import type { Page } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import PostCard from "@/components/PostCard.astro";
import Pagination from "@/components/Pagination.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { slugifyStr } from "@/utils/slugify";
import { toTransitionName } from "@/utils/toTransitionName";
import { useTranslations, tplStr } from "@/i18n";
import { getCardWidth } from "@/utils/getCardWidth";
import config from "@/config";

interface Props {
  page: Page<CollectionEntry<"posts">>;
  categoryName: string;
}

const { page, categoryName } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

/** 与分类索引页保持一致的 transition 名称（基于 slug） */
const categoryTransition = toTransitionName(slugifyStr(categoryName));

const title = tplStr(t.pages.categoryTitle, { category: categoryName });
const description = tplStr(t.pages.categoryDesc, { category: categoryName });
const crumbs = [
  { href: getRelativeLocaleUrl(locale), label: t.nav.home },
  { href: getRelativeLocaleUrl(locale, "categories"), label: t.pages.categoriesTitle },
  { label: categoryName },
];
---

<Layout title={title} description={description}>
  <Header />
  <Main>
    <Breadcrumb items={crumbs} class="mb-6" />
    <h1
      transition:name={categoryTransition}
      class="mb-6 text-3xl font-bold tracking-tight sm:text-4xl"
    >
      {categoryName}
    </h1>
    <p class="mb-8 text-muted-foreground">{description}</p>
    <ul class="grid grid-cols-2 items-start gap-4">
      {page.data.map((post) => {
        const width = getCardWidth(post, config.features.showPostCardHero);
        return (
          <li class={width === "full" ? "col-span-2" : "col-span-1"}>
            <PostCard post={post} />
          </li>
        );
      })}
    </ul>
    <Pagination page={page} />
  </Main>
  <Footer />
</Layout>
