---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const title = t.pages.searchTitle;
const description = t.pages.searchDesc;
const crumbs = [
  { href: getRelativeLocaleUrl(locale), label: t.nav.home },
  { label: title },
];
---

<Layout title={title} description={description}>
  <Header />
  <Main>
    <Breadcrumb items={crumbs} class="mb-6" />
    <h1 class="mb-6 text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
    <p class="mb-8 text-muted-foreground">{description}</p>

    <div id="flexsearch-ui" transition:persist class="space-y-6">
      <!-- 搜索输入框 -->
      <div class="relative">
        <svg
          class="search-icon absolute left-3 top-1/2 size-5 -translate-y-1/2 text-muted-foreground"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.3-4.3" />
        </svg>
        <input
          id="search-input"
          type="search"
          placeholder={t.a11y.searchPlaceholder}
          class="search-input w-full rounded-md border border-input bg-background py-3 pl-10 pr-10 text-foreground placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary"
          autocomplete="off"
          autocorrect="off"
          spellcheck="false"
          enterkeyhint="search"
        />
        <button
          id="search-clear"
          class="search-clear absolute right-3 top-1/2 hidden -translate-y-1/2 text-muted-foreground transition-colors hover:text-foreground"
          aria-label={t.post.copyCode}
          type="button"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-4"
          >
            <path d="M18 6 6 18" />
            <path d="m6 6 12 12" />
          </svg>
        </button>
      </div>

      <!-- 搜索统计 -->
      <div id="search-stats" class="hidden text-sm text-muted-foreground"></div>

      <!-- 搜索结果列表 -->
      <div id="search-results" class="space-y-4" role="list" aria-label={t.pages.searchTitle}>
        <!-- 初始提示 -->
        <div id="search-hint" class="py-12 text-center text-muted-foreground">
          <svg
            class="mx-auto mb-4 size-12 opacity-40"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.3-4.3" />
          </svg>
          <p>{t.a11y.searchPlaceholder}</p>
        </div>
        <!-- 无结果提示（由 JS 控制显示） -->
        <div id="search-no-results" class="hidden py-12 text-center text-muted-foreground">
          <p>{t.a11y.noResults}</p>
        </div>
      </div>
    </div>
  </Main>
  <Footer />
</Layout>

<script>
  import FlexSearch from "flexsearch";
  import { getAssetPath } from "@/utils/withBase";

  /** 搜索文档结构（兼容 Flexsearch DocumentData） */
  interface SearchDoc {
    [key: string]: unknown;
    id: string;
    title: string;
    description: string;
    pubDatetime: string;
    modDatetime: string;
    tags: string[];
    category: string;
    url: string;
    content: string;
  }

  /** Flexsearch 文档搜索结果项 */
  interface FieldResult {
    field: string;
    result: Array<{ doc: SearchDoc }>;
  }

  /** 搜索状态（挂载到 container 上，跨 View Transitions 持久化） */
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  type FlexIndex = any;
  interface SearchState {
    index: FlexIndex | null;
    documents: SearchDoc[];
    locale: string;
    params: URLSearchParams;
    debounceTimer: ReturnType<typeof setTimeout> | null;
    input: HTMLInputElement | null;
    clearBtn: HTMLElement | null;
    resultsEl: HTMLElement | null;
    hintEl: HTMLElement | null;
    noResultsEl: HTMLElement | null;
    statsEl: HTMLElement | null;
  }

  /** 从 container 获取或创建搜索状态 */
  function getSearchState(container: HTMLElement): SearchState {
    const key = "_searchState";
    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    if ((container as any)[key]) // eslint-disable-next-line @typescript-eslint/no-explicit-any
    return (container as any)[key];
    const state: SearchState = {
      index: null,
      documents: [],
      locale: "",
      params: new URLSearchParams(window.location.search),
      debounceTimer: null,
      input: null,
      clearBtn: null,
      resultsEl: null,
      hintEl: null,
      noResultsEl: null,
      statsEl: null,
    };
    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    (container as any)[key] = state;
    return state;
  }

  /** 获取当前语言代码 */
  function detectLocale(): string {
    const path = window.location.pathname.replace(/\/+$/, "");
    const segments = path.split("/");
    const locales = [
      "zh-cn", "zh-tw", "en", "ja", "ko", "fr",
      "de", "es", "pt", "ru", "ar", "eo",
    ];
    for (let i = 1; i < segments.length; i++) {
      if (locales.includes(segments[i])) return segments[i];
    }
    return "zh-cn";
  }

  /** 搜索结果入场动画 */
  function observeSearchResults(container: HTMLElement) {
    const addAnim = (el: Element) => {
      if (!el.classList.contains("search-result-enter")) {
        el.classList.add("search-result-enter");
      }
    };
    container.querySelectorAll(".search-result-card").forEach(addAnim);
    const obs = new MutationObserver(() => {
      container.querySelectorAll(".search-result-card").forEach(addAnim);
    });
    obs.observe(container, { childList: true, subtree: true });
  }

  /** 高亮搜索关键词 */
  function highlightText(text: string, query: string): string {
    if (!query || !text) return escapeHtml(text);
    const terms = query
      .split(/\s+/)
      .filter(Boolean)
      .map((t) => t.replace(/[.*+?^${}()|[\]\\]/g, "\\$&"));
    if (terms.length === 0) return escapeHtml(text);
    const escapedTerms = terms.map((t) => escapeHtml(t));
    return escapeHtml(text).replace(
      new RegExp(`(${escapedTerms.join("|")})`, "gi"),
      '<mark class="search-highlight">$1</mark>',
    );
  }

  /** HTML 转义 */
  function escapeHtml(str: string): string {
    const div = document.createElement("div");
    div.textContent = str;
    return div.innerHTML;
  }

  /** 截取文本片段用于上下文展示 */
  function getContextSnippet(text: string, query: string, contextLen = 80): string {
    if (!query || !text) return text ? text.slice(0, 200) : "";
    const lowerText = text.toLowerCase();
    const lowerQuery = query.toLowerCase();
    const idx = lowerText.indexOf(lowerQuery);
    if (idx === -1) return text.slice(0, 200);
    const start = Math.max(0, idx - contextLen);
    const end = Math.min(text.length, idx + query.length + contextLen);
    let snippet = text.slice(start, end);
    if (start > 0) snippet = "..." + snippet;
    if (end < text.length) snippet = snippet + "...";
    return snippet;
  }

  /**
   * 提取正文中匹配关键词的片段，优先展示含匹配词的相邻句子
   * 返回带上下文的关键词附近正文片段
   */
  function getContentMatchSnippet(content: string, query: string): string {
    if (!query || !content) return "";
    // 如果是描述已包含匹配，不重复展示正文片段
    const lowerContent = content.toLowerCase();
    const lowerQuery = query.toLowerCase();
    const idx = lowerContent.indexOf(lowerQuery);
    if (idx === -1) return "";
    // 以 150 字符为窗口展示匹配词附近内容
    const ctxLen = 75;
    const start = Math.max(0, idx - ctxLen);
    const end = Math.min(content.length, idx + query.length + ctxLen);
    let snippet = content.slice(start, end);
    // 尝试在句号/换行处分隔
    snippet = snippet.replace(/^[^。\n]{0,20}[\.。\n]?/, "").trim();
    if (start > 0 && !snippet.startsWith("...")) snippet = "..." + snippet;
    if (end < content.length && !snippet.endsWith("...")) snippet = snippet + "...";
    return snippet.slice(0, 300);
  }

  /** 创建搜索结果卡片 */
  function createResultCard(
    doc: SearchDoc,
    query: string,
  ): HTMLAnchorElement {
    const card = document.createElement("a");
    card.href = doc.url;
    card.className =
      "search-result-card block rounded-lg border border-border bg-card p-4 transition-colors hover:bg-accent hover:shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary";
    card.setAttribute("role", "listitem");

    // 标题
    const titleEl = document.createElement("h3");
    titleEl.className = "mb-1 text-lg font-semibold text-primary";
    titleEl.innerHTML = highlightText(doc.title, query);
    card.appendChild(titleEl);

    // 元信息行：日期 + 分类
    const metaEl = document.createElement("div");
    metaEl.className = "mb-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-muted-foreground";
    if (doc.pubDatetime) {
      const dateEl = document.createElement("span");
      dateEl.className = "inline-flex items-center gap-1";
      try {
        const d = new Date(doc.pubDatetime);
        dateEl.textContent = "发布于 " + d.toLocaleDateString("zh-CN", {
          year: "numeric",
          month: "2-digit",
          day: "2-digit",
        });
      } catch {
        dateEl.textContent = "发布于 " + doc.pubDatetime.slice(0, 10);
      }
      metaEl.appendChild(dateEl);

      // 更新时间
      if (doc.modDatetime) {
        try {
          const modD = new Date(doc.modDatetime);
          const pubD = new Date(doc.pubDatetime);
          if (modD > pubD) {
            const sep = document.createTextNode(" · ");
            metaEl.appendChild(sep);
            const modEl = document.createElement("span");
            modEl.className = "inline-flex items-center gap-1";
            modEl.textContent = "更新于 " + modD.toLocaleDateString("zh-CN", {
              year: "numeric",
              month: "2-digit",
              day: "2-digit",
            });
            metaEl.appendChild(modEl);
          }
        } catch {
          // ignore modDatetime parse errors
        }
      }
    }
    if (doc.category) {
      const catEl = document.createElement("span");
      catEl.className =
        "inline-flex items-center rounded-sm bg-primary/10 px-1.5 py-0.5 text-xs font-medium text-primary";
      catEl.textContent = doc.category;
      metaEl.appendChild(catEl);
    }
    if (metaEl.children.length > 0) {
      card.appendChild(metaEl);
    }

    // 正文摘要（优先匹配正文上下文，回退到描述）
    const descEl = document.createElement("p");
    descEl.className = "mb-2 text-sm text-muted-foreground line-clamp-3";
    const descSnippet = getContextSnippet(doc.description || doc.content, query);
    descEl.innerHTML = highlightText(descSnippet, query);
    card.appendChild(descEl);

    // 匹配正文片段（展示含匹配词的一段正文）
    const contentSnippet = getContentMatchSnippet(doc.content, query);
    if (contentSnippet) {
      const contentEl = document.createElement("p");
      contentEl.className = "mb-2 text-xs text-muted-foreground/70 line-clamp-2 italic";
      contentEl.innerHTML = highlightText(contentSnippet, query);
      card.appendChild(contentEl);
    }

    // 标签行
    if (doc.tags && doc.tags.length > 0) {
      const tagsEl = document.createElement("div");
      tagsEl.className = "flex flex-wrap gap-1.5";
      doc.tags.slice(0, 5).forEach((tag: string) => {
        const tagEl = document.createElement("span");
        tagEl.className =
          "inline-block rounded-sm bg-muted px-1.5 py-0.5 text-xs text-muted-foreground";
        tagEl.textContent = tag;
        tagsEl.appendChild(tagEl);
      });
      card.appendChild(tagsEl);
    }

    return card;
  }

  /** 执行搜索 */
  function performSearch(state: SearchState, query: string) {
    if (!query.trim()) {
      showHint(state);
      return;
    }
    if (!state.index) {
      textSearch(state, query);
      return;
    }
    const rawResults = (state.index as FlexIndex).search(query, {
      limit: 50,
      enrich: true,
    }) as FieldResult[];
    const resultMap = new Map<string, { doc: SearchDoc; fields: Set<string> }>();
    if (rawResults && rawResults.length > 0) {
      for (const fieldResult of rawResults) {
        if (fieldResult.result && fieldResult.result.length > 0) {
          for (const item of fieldResult.result) {
            const doc = item.doc;
            if (doc && doc.id) {
              if (!resultMap.has(doc.id)) {
                resultMap.set(doc.id, { doc, fields: new Set() });
              }
              resultMap.get(doc.id)!.fields.add(fieldResult.field);
            }
          }
        }
      }
    }
    const results = Array.from(resultMap.values());
    if (results.length === 0) {
      textSearch(state, query);
      return;
    }
    renderResults(state, results, query);
  }

  /** 纯文本搜索（索引未加载时的降级方案） */
  function textSearch(state: SearchState, query: string) {
    const lowerQuery = query.toLowerCase();
    const results = state.documents
      .filter((doc: SearchDoc) => {
        const searchText =
          `${doc.title} ${doc.description} ${doc.content} ${(doc.tags || []).join(" ")}`.toLowerCase();
        return searchText.includes(lowerQuery);
      })
      .map((doc: SearchDoc) => ({ doc, fields: new Set(["content"]) }));
    if (results.length === 0) {
      showNoResults(state);
      return;
    }
    renderResults(state, results, query);
  }

  /** 渲染搜索结果 */
  function renderResults(
    state: SearchState,
    results: Array<{ doc: SearchDoc; fields: Set<string> }>,
    query: string,
  ) {
    state.hintEl?.classList.add("hidden");
    state.noResultsEl?.classList.add("hidden");
    state.resultsEl!.innerHTML = "";
    if (state.statsEl) {
      state.statsEl.textContent = `${results.length} 条结果`;
      state.statsEl.classList.remove("hidden");
    }
    for (const { doc } of results) {
      const card = createResultCard(doc, query);
      state.resultsEl!.appendChild(card);
    }
    state.params.set("q", query);
    history.replaceState(history.state, "", "?" + state.params.toString());
    sessionStorage.setItem(
      "backUrl",
      `${window.location.pathname}?${state.params.toString()}`,
    );
    observeSearchResults(state.resultsEl!);
  }

  /** 显示初始提示 */
  function showHint(state: SearchState) {
    state.hintEl?.classList.remove("hidden");
    state.noResultsEl?.classList.add("hidden");
    state.resultsEl!.innerHTML = "";
    state.statsEl?.classList.add("hidden");
  }

  /** 显示无结果提示 */
  function showNoResults(state: SearchState) {
    state.hintEl?.classList.add("hidden");
    state.noResultsEl?.classList.remove("hidden");
    state.resultsEl!.innerHTML = "";
    state.statsEl?.classList.add("hidden");
  }

  /** 加载并初始化搜索索引 */
  async function loadIndex(state: SearchState, container: HTMLElement) {
    try {
      let dataUrl = getAssetPath(`search/${state.locale}.json`);
      let resp = await fetch(dataUrl);
      if (!resp.ok) {
        const manifestUrl = getAssetPath("search/manifest.json");
        const manifestResp = await fetch(manifestUrl);
        if (!manifestResp.ok) {
          console.warn("[search] 搜索索引清单不存在");
          return;
        }
        const manifest = await manifestResp.json();
        if (manifest.length === 0) return;
        const lang = manifest.includes(state.locale) ? state.locale : manifest[0];
        dataUrl = getAssetPath(`search/${lang}.json`);
        resp = await fetch(dataUrl);
        if (!resp.ok) return;
      }
      state.documents = await resp.json();
      if (!state.documents || state.documents.length === 0) return;

      // 初始化 Flexsearch Document 索引
      state.index = new FlexSearch.Document({
        document: {
          id: "id",
          index: [
            { field: "title", tokenize: "forward", resolution: 9 },
            { field: "description", tokenize: "forward", resolution: 5 },
            { field: "content", tokenize: "forward", resolution: 3 },
            { field: "tags", tokenize: "forward", resolution: 5 },
          ],
          store: ["title", "description", "pubDatetime", "modDatetime", "tags", "category", "url", "content"],
        },
        tokenize: "forward",
        cache: true,
      });

      for (const doc of state.documents) {
        (state.index as FlexIndex).add(doc);
      }

      // 标记搜索已就绪
      container.dataset.searchReady = "true";

      // 触发 URL 中的初始查询
      const query = state.params.get("q");
      if (query && state.input) {
        state.input.value = query;
        performSearch(state, query);
      }
    } catch (err) {
      console.warn("[search] 索引加载失败：", err);
    }
  }

  /** 绑定事件监听器 */
  function bindEvents(state: SearchState, container: HTMLElement) {
    if (!state.input) return;

    // 移除旧监听器（用新函数替换）
    const oldInput = state.input;
    const newInput = oldInput.cloneNode(true) as HTMLInputElement;
    oldInput.parentNode?.replaceChild(newInput, oldInput);
    state.input = newInput;

    // 重新查询 DOM 元素（clearBtn 也被 clone 替换了）
    state.clearBtn = container.querySelector("#search-clear");
    state.resultsEl = container.querySelector("#search-results");
    state.hintEl = container.querySelector("#search-hint");
    state.noResultsEl = container.querySelector("#search-no-results");
    state.statsEl = container.querySelector("#search-stats");

    const newClearBtn = state.clearBtn;

    // 输入事件
    newInput.addEventListener("input", (e: Event) => {
      const target = e.target as HTMLInputElement;
      const query = target.value.trim();
      if (query) {
        if (newClearBtn) newClearBtn.classList.remove("hidden");
        if (state.debounceTimer) clearTimeout(state.debounceTimer);
        state.debounceTimer = setTimeout(() => {
          performSearch(state, query);
        }, 200);
      } else {
        if (newClearBtn) newClearBtn.classList.add("hidden");
        if (state.debounceTimer) clearTimeout(state.debounceTimer);
        showHint(state);
        history.replaceState(history.state, "", window.location.pathname);
      }
    });

    // 清除按钮
    newClearBtn?.addEventListener("click", () => {
      newInput.value = "";
      newClearBtn.classList.add("hidden");
      if (state.debounceTimer) clearTimeout(state.debounceTimer);
      showHint(state);
      history.replaceState(history.state, "", window.location.pathname);
      newInput.focus();
    });

    // 如果已有查询参数，触发搜索
    const query = state.params.get("q");
    if (query) {
      newInput.value = query;
      if (newClearBtn) newClearBtn.classList.remove("hidden");
      if (container.dataset.searchReady === "true") {
        performSearch(state, query);
      }
    }
  }

  /** 主初始化函数 */
  function initSearch() {
    const container = document.querySelector<HTMLElement>("#flexsearch-ui");
    if (!container) return;

    const state = getSearchState(container);
    state.input = container.querySelector("#search-input");
    state.clearBtn = container.querySelector("#search-clear");
    state.resultsEl = container.querySelector("#search-results");
    state.hintEl = container.querySelector("#search-hint");
    state.noResultsEl = container.querySelector("#search-no-results");
    state.statsEl = container.querySelector("#search-stats");
    state.locale = detectLocale();
    state.params = new URLSearchParams(window.location.search);

    if (!state.input || !state.resultsEl) return;

    // 绑定事件（每次 initSearch 都重新绑定，解决 View Transitions 后事件丢失问题）
    bindEvents(state, container);

    // 仅在索引未加载时加载
    if (container.dataset.searchReady !== "true") {
      loadIndex(state, container);

      // 开发模式提示
      if (import.meta.env.DEV) {
        const devNotice = document.createElement("div");
        devNotice.className = "mb-4 rounded-md bg-muted p-4 text-sm";
        devNotice.innerHTML = `
          <p><strong>开发模式提示：</strong>需至少构建一次项目才能看到搜索结果。</p>
          <code class="mt-2 block rounded bg-background px-2 py-1">pnpm run build</code>
        `;
        container.prepend(devNotice);
      }
    } else {
      // 索引已加载，检查是否需要恢复 URL 查询
      const query = state.params.get("q");
      if (query && state.input.value !== query) {
        state.input.value = query;
        performSearch(state, query);
      }
    }
  }

  // 首次加载
  initSearch();

  // View Transitions 导航后重新绑定事件
  document.addEventListener("astro:after-swap", () => {
    initSearch();
  });
</script>

<style is:global>
  /* 搜索图标颜色 */
  #flexsearch-ui .search-icon {
    pointer-events: none;
  }

  /* 清除按钮在输入框有内容时显示 */
  #flexsearch-ui .search-clear {
    display: none;
  }

  /* 搜索结果卡片入场动画 */
  #flexsearch-ui .search-result-card.search-result-enter {
    animation: searchResultFadeIn 0.3s ease-out both;
  }

  @keyframes searchResultFadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* 搜索结果入场动画交错延迟 */
  #flexsearch-ui .search-result-card:nth-child(1).search-result-enter {
    animation-delay: 0ms;
  }
  #flexsearch-ui .search-result-card:nth-child(2).search-result-enter {
    animation-delay: 40ms;
  }
  #flexsearch-ui .search-result-card:nth-child(3).search-result-enter {
    animation-delay: 80ms;
  }
  #flexsearch-ui .search-result-card:nth-child(4).search-result-enter {
    animation-delay: 120ms;
  }
  #flexsearch-ui .search-result-card:nth-child(5).search-result-enter {
    animation-delay: 160ms;
  }
  #flexsearch-ui .search-result-card:nth-child(6).search-result-enter {
    animation-delay: 200ms;
  }
  #flexsearch-ui .search-result-card:nth-child(7).search-result-enter {
    animation-delay: 240ms;
  }
  #flexsearch-ui .search-result-card:nth-child(8).search-result-enter {
