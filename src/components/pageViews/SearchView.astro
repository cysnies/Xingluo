---
import "@pagefind/default-ui/css/ui.css";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { getAssetPath } from "@/utils/withBase";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

// 搜索未启用时重定向到 404
const notFoundUrl = getRelativeLocaleUrl(locale, "404");
if (config.features.search !== "pagefind" && notFoundUrl) {
  return Astro.rewrite(notFoundUrl);
}

const pagefindBundlePath = getAssetPath("pagefind/");
const title = t.pages.searchTitle;
const description = t.pages.searchDesc;
const crumbs = [
  { href: getRelativeLocaleUrl(locale), label: t.nav.home },
  { label: title },
];
---

<Layout title={title} description={description}>
  <Header />
  <Main>
    <Breadcrumb items={crumbs} class="mb-6" />
    <h1 class="mb-6 text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
    <p class="mb-8 text-muted-foreground">{description}</p>

    <div
      id="pagefind-search"
      transition:persist
      data-bundle-path={pagefindBundlePath}
    >
    </div>
  </Main>
  <Footer />
</Layout>

<script>
  /** 为搜索结果添加入场动画 */
  function observeSearchResults(searchEl: HTMLElement) {
    const addAnimToResult = (result: Element) => {
      if (!result.classList.contains("search-result-enter")) {
        result.classList.add("search-result-enter");
      }
    };

    // 处理已有结果
    searchEl.querySelectorAll(".pagefind-ui__result").forEach(addAnimToResult);

    // 监听后续新增的结果
    const obs = new MutationObserver(() => {
      searchEl.querySelectorAll(".pagefind-ui__result").forEach(addAnimToResult);
    });
    obs.observe(searchEl, { childList: true, subtree: true });
  }

  function initSearch() {
    const pageFindSearch = document.querySelector<HTMLElement>(
      "#pagefind-search"
    );
    if (!pageFindSearch) return;

    const bundlePath = pageFindSearch.dataset.bundlePath;
    if (!bundlePath) return;

    const params = new URLSearchParams(window.location.search);
    const onIdle =
      window.requestIdleCallback || ((cb: () => void) => setTimeout(cb, 1));

    onIdle(async () => {
      // @ts-expect-error - @pagefind/default-ui 缺少类型声明
      const { PagefindUI } = await import("@pagefind/default-ui");

      // 开发模式提示需先构建
      if (import.meta.env.DEV) {
        pageFindSearch.innerHTML = `
          <div class="mb-4 rounded-md bg-muted p-4 text-sm">
            <p><strong>开发模式提示：</strong>需至少构建一次项目才能看到搜索结果。</p>
            <code class="mt-2 block rounded bg-background px-2 py-1">pnpm run build</code>
          </div>
        `;
      }

      const search = new PagefindUI({
        element: "#pagefind-search",
        bundlePath,
        showImages: false,
        showSubResults: true,
        processTerm: function (term: string) {
          params.set("q", term);
          history.replaceState(history.state, "", "?" + params.toString());
          // 记录带查询参数的搜索页地址，供文章页返回按钮回跳到搜索结果
          sessionStorage.setItem("backUrl", `${window.location.pathname}?${params.toString()}`);
          return term;
        },
      });

      // 为搜索结果添加入场动画
      observeSearchResults(pageFindSearch);

      // 触发 URL 中的初始查询
      const query = params.get("q");
      if (query) {
        search.triggerSearch(query);
      }

      // 清空搜索时重置 URL 参数
      const searchInput = document.querySelector(".pagefind-ui__search-input");
      const clearButton = document.querySelector(".pagefind-ui__search-clear");
      const resetSearchParam = (e: Event) => {
        if ((e.target as HTMLInputElement)?.value.trim() === "") {
          history.replaceState(history.state, "", window.location.pathname);
        }
      };
      searchInput?.addEventListener("input", resetSearchParam);
      clearButton?.addEventListener("click", resetSearchParam);
    });
  }

  document.addEventListener("astro:after-swap", () => {
    const pagefindSearch = document.querySelector("#pagefind-search");
    // 已存在搜索表单则不重复初始化
    if (pagefindSearch && pagefindSearch.querySelector("form")) return;
    initSearch();
  });
  initSearch();
</script>

<style is:global>
  #pagefind-search {
    --pagefind-ui-font: var(--font-sans);
    --pagefind-ui-text: var(--foreground);
    --pagefind-ui-background: var(--background);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-primary: var(--primary);
    --pagefind-ui-tag: var(--background);
    --pagefind-ui-border-radius: 0.375rem;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-image-box-ratio: 3 / 2;
  }

  /* 搜索框前缀图标配色 */
  #pagefind-search form::before {
    background-color: var(--foreground);
  }

  /* 输入框聚焦态使用主色描边 */
  #pagefind-search input {
    font-weight: 400;
    border: 1px solid var(--border);
  }
  #pagefind-search input:focus-visible {
    outline: 1px solid var(--primary);
  }

  /* 结果标题链接：主色 + 虚线下划线 */
  #pagefind-search .pagefind-ui__result-title a {
    color: var(--primary);
    outline-offset: 1px;
    outline-color: var(--primary);
    text-decoration-style: dashed;
    text-underline-offset: 4px;
  }
  #pagefind-search .pagefind-ui__result-title a:focus-visible,
  #pagefind-search .pagefind-ui__search-clear:focus-visible {
    text-decoration-line: none;
    outline-width: 2px;
    outline-style: dashed;
  }

  /* 最后一条结果去除底边 */
  #pagefind-search .pagefind-ui__result:last-of-type {
    border-bottom: 0;
  }

  /* 子结果前缀图标使用系统字体 */
  #pagefind-search .pagefind-ui__result-nested .pagefind-ui__result-link:before {
    font-family: system-ui;
  }
</style>
