---
import { type CollectionEntry } from "astro:content";
import { render } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import PostLayout from "@/layouts/PostLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Datetime from "@/components/Datetime.astro";
import Tag from "@/components/Tag.astro";
import { getPostUrl } from "@/utils/getPostPaths";
import { slugifyStr } from "@/utils/slugify";
import { toTransitionName } from "@/utils/toTransitionName";
import { resolveDefaultOgImagePath } from "@/utils/resolveDefaultOgImagePath";
import { useTranslations, tplStr } from "@/i18n";
import { DEFAULT_LOCALE } from "@/i18n";
import { getReadingTime } from "@/utils/readingTime";
import { getPostLocale } from "@/utils/i18nPosts";
import EditPost from "@/components/post/EditPost.astro";
import ShareLinks from "@/components/post/ShareLinks.astro";
import BackButton from "@/components/post/BackButton.astro";
import BackToTopButton from "@/components/post/BackToTopButton.astro";
import AdjacentPostNav from "@/components/post/AdjacentPostNav.astro";
import RelatedPosts from "@/components/post/RelatedPosts.astro";
import TableOfContents from "@/components/post/TableOfContents.astro";
import Comments from "@/components/comments/Comments.astro";
import Clock from "@/assets/icons/Clock.astro";
import config from "@/config";

interface Props {
  post: CollectionEntry<"posts">;
  prevPost: CollectionEntry<"posts"> | null;
  nextPost: CollectionEntry<"posts"> | null;
  relatedPosts?: CollectionEntry<"posts">[];
}

const { post, prevPost, nextPost, relatedPosts = [] } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const {
  title,
  description,
  ogImage: initOgImage,
  heroImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
  category,
  comments,
} = post.data;

const { Content, headings } = await render(post);

/** 分类链接：设置 category 时生成对应分类页地址 */
const categoryHref = category
  ? getRelativeLocaleUrl(locale, `categories/${slugifyStr(category)}/`)
  : undefined;

/** 解析 OG 图地址：字符串直接用，image 对象取 src，未配置则按功能开关回退 */
let ogImageUrl: string | undefined;
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage;
} else if (initOgImage && typeof initOgImage === "object" && "src" in initOgImage) {
  ogImageUrl = initOgImage.src;
}
if (!ogImageUrl) {
  // 启用动态 OG 图时使用文章级生成图，否则回退到站点默认静态图
  ogImageUrl = config.features.dynamicOgImage
    ? `${getPostUrl(post.id, post.filePath, locale)}/og.png`
    : resolveDefaultOgImagePath();
}
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

/**
 * 头图地址解析：
 * - image() 对象取 .src（经 Astro 资源管线优化后的带哈希路径）
 * - 字符串直接作为 public/ 路径或外链使用
 * - 未设置时不渲染头图
 * 仅在全局开关 showPostDetailHero 开启时才解析与展示
 */
let heroImageSrc: string | undefined;
if (config.features.showPostDetailHero) {
  if (typeof heroImage === "string") {
    heroImageSrc = heroImage;
  } else if (heroImage && typeof heroImage === "object" && "src" in heroImage) {
    heroImageSrc = heroImage.src;
  }
}

/** 编辑链接所需的相对源文件路径 */
const editPath = post.filePath?.replace(/^src\//, "") ?? "";
const articleUrl = new URL(getPostUrl(post.id, post.filePath, locale), Astro.site).href;

/** 阅读时长（分钟）：按当前语言的字符/单词速率估算 */
const readingMinutes = getReadingTime(post.body ?? "", locale);

/**
 * canonical 规范化：
 * - 文章自定义了 canonicalURL 时优先使用
 * - 当前文章为该语言的真实译文（locale 与路由语言一致）时指向自身
 * - 否则为回退内容（无独立译文），指向默认语言原文，避免重复内容判定
 */
const isTranslated = getPostLocale(post) === locale;
const resolvedCanonical =
  canonicalURL ??
  (isTranslated
    ? articleUrl
    : new URL(getPostUrl(post.id, post.filePath, DEFAULT_LOCALE), Astro.site).href);
---

<PostLayout
  title={`${title} | ${config.site.title}`}
  description={description}
  ogImage={ogImage}
  canonicalURL={resolvedCanonical}
  pubDatetime={pubDatetime}
  modDatetime={modDatetime ?? undefined}
>
  <Header />

  <main
    id="main-content"
    class="mx-auto w-full max-w-app flex-1 px-4 py-8 sm:px-6 lg:max-w-[90rem] lg:px-8"
    data-pagefind-body
  >
    {config.features.showBackButton && <BackButton />}

    {heroImageSrc && (
      <img
        src={heroImageSrc}
        alt=""
        loading="lazy"
        decoding="async"
        class="mt-4 mb-2 w-full rounded-lg border border-border object-cover"
      />
    )}

    <article class="mt-4">
      <h1
        style={{ viewTransitionName: toTransitionName(title) }}
        class="text-3xl font-bold tracking-tight sm:text-4xl"
      >
        {title}
      </h1>

      <div class="mt-3 flex flex-wrap items-center gap-3">
        <Datetime
          pubDatetime={pubDatetime}
          modDatetime={modDatetime}
          timezone={timezone}
          size="lg"
        />
        <span class="flex items-center gap-x-1.5 text-muted-foreground">
          <Clock class="size-4 shrink-0 scale-90" />
          <span class="text-sm sm:text-base">
            {tplStr(t.post.readingTime, { minutes: readingMinutes })}
          </span>
        </span>
        <EditPost editPath={editPath} hide={hideEditPost} />
      </div>

      {/* 大屏双列：主文章 + 粘性目录侧栏；小屏仅单列（目录隐藏） */}
      <div class="mt-8 lg:grid lg:grid-cols-[minmax(0,1fr)_16rem] lg:gap-10">
        <div class="min-w-0">
          <article
            id="article"
            data-copy={t.post.copyCode}
            data-copied={t.post.copied}
            data-zoom={t.post.zoomImage}
            data-preview={t.post.imagePreview}
            data-close={t.post.closeImagePreview}
            class="app-prose max-w-app"
          >
            <Content />
          </article>

          <hr class="my-8 border-dashed border-border" />

          <div class="mb-8 flex flex-wrap items-center gap-2">
            {categoryHref && (
              <a
                href={categoryHref}
                class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary transition-colors hover:bg-primary/20"
              >
                {category}
              </a>
            )}
            {tags.map((tag) => (
              <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />
            ))}
          </div>

          <ShareLinks url={articleUrl} title={title} />

          <AdjacentPostNav prevPost={prevPost ?? undefined} nextPost={nextPost ?? undefined} />

          <RelatedPosts posts={relatedPosts} />

          {/* 评论区：受文章 frontmatter comments 字段覆盖，未设置时跟随全局配置 */}
          <Comments locale={locale} enabled={comments} />
        </div>

        <aside class="hidden lg:block" aria-label={t.post.tableOfContents}>
          <div class="sticky top-20 max-h-[calc(100dvh-6rem)] overflow-y-auto pe-1">
            <TableOfContents headings={headings} label={t.post.tableOfContents} />
          </div>
        </aside>
      </div>
    </article>
  </main>

  <BackToTopButton />
  <Footer />
</PostLayout>

<script>
  import "@/scripts/postEnhancements";
  import "@/scripts/toc";
</script>

{
  /* 播放器客户端脚本：仅当任一播放器启用时加载，由脚本内部按占位元素懒实例化 */
  (config.features.players.aplayer || config.features.players.dplayer) && (
    <script>
      import "@/scripts/players";
    </script>
  )
}
