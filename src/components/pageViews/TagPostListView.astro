---
import { type CollectionEntry } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import type { Page } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import PostCard from "@/components/PostCard.astro";
import Pagination from "@/components/Pagination.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { useTranslations, tplStr } from "@/i18n";
import config from "@/config";

interface Props {
  page: Page<CollectionEntry<"posts">>;
  tagName: string;
}

const { page, tagName } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const title = tplStr(t.pages.tagTitle, { tag: tagName });
const description = tplStr(t.pages.tagDesc, { tag: tagName });
const crumbs = [
  { href: getRelativeLocaleUrl(locale), label: t.nav.home },
  { href: getRelativeLocaleUrl(locale, "tags"), label: t.pages.tagsTitle },
  { label: tagName },
];
---

<Layout title={title} description={description}>
  <Header />
  <Main>
    <Breadcrumb items={crumbs} class="mb-6" />
    <h1 class="mb-6 text-3xl font-bold tracking-tight sm:text-4xl">#{tagName}</h1>
    <p class="mb-8 text-muted-foreground">{description}</p>
    <ul class="grid gap-4 sm:grid-cols-2">
      {page.data.map((post) => (
        <li>
          <PostCard post={post} />
        </li>
      ))}
    </ul>
    <Pagination page={page} />
  </Main>
  <Footer />
</Layout>
