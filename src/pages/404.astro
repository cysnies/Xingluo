---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { useTranslations } from "@/i18n";
import config from "@/config";
import Button from "@/components/ui/Button.astro";

const t = useTranslations(Astro.currentLocale);
const locale = Astro.currentLocale ?? config.site.lang;
const homeHref = getRelativeLocaleUrl(locale);
---

<Layout title={t.notFound.title}>
  <Header />
  <main id="main-content" class="mx-auto flex w-full max-w-app flex-1 flex-col items-center justify-center px-4 py-16 text-center sm:px-6 lg:px-8">
    <p class="text-6xl font-bold text-muted-foreground">404</p>
    <h1 class="mt-4 text-2xl font-semibold tracking-tight">{t.notFound.title}</h1>
    <p class="mt-2 text-muted-foreground">{t.notFound.message}</p>
    <Button href={homeHref} class="mt-6">
      {t.notFound.goHome}
    </Button>
  </main>
  <Footer />
</Layout>
