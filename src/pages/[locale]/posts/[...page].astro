---
import { getCollection } from "astro:content";
import PostListView from "@/components/pageViews/PostListView.astro";
import { getPostsForLocale } from "@/utils/i18nPosts";
import { NON_DEFAULT_LOCALES } from "@/i18n/staticPaths";
import config from "@/config";

export async function getStaticPaths({ paginate }: any) {
  const allPosts = await getCollection("posts");
  // 为每个非默认语言生成分页，按该语言代表文章列表
  return NON_DEFAULT_LOCALES.flatMap((locale) =>
    paginate(getPostsForLocale(allPosts, locale), {
      params: { locale },
      pageSize: config.posts.perPage,
    })
  );
}

const { page } = Astro.props as { page: any };
---

<PostListView page={page} />
