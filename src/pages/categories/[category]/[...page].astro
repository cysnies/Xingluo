---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import CategoryPostListView from "@/components/pageViews/CategoryPostListView.astro";
import { getPostsForLocale } from "@/utils/i18nPosts";
import { getUniqueCategories } from "@/utils/getUniqueCategories";
import { slugifyStr } from "@/utils/slugify";
import { DEFAULT_LOCALE } from "@/i18n";
import config from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("posts");
  const sortedPosts = getPostsForLocale(posts, DEFAULT_LOCALE);
  const categories = getUniqueCategories(sortedPosts);

  return categories.flatMap(({ category, categoryName }) => {
    const categoryPosts = sortedPosts.filter(
      ({ data }) => data.category && slugifyStr(data.category) === category
    );
    return paginate(categoryPosts, {
      params: { category },
      props: { categoryName },
      pageSize: config.posts.perPage,
    });
  });
}

const { page, categoryName } = Astro.props as {
  page: any;
  categoryName: string;
};
---

<CategoryPostListView page={page} categoryName={categoryName} />
