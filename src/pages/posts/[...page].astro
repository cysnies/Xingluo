---
import { getCollection } from "astro:content";
import PostListView from "@/components/pageViews/PostListView.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import config from "@/config";

export async function getStaticPaths({ paginate }: any) {
  const allPosts = await getCollection("posts");
  const sorted = getSortedPosts(allPosts);
  return paginate(sorted, { pageSize: config.posts.perPage });
}

const { page } = Astro.props as { page: any };
---

<PostListView page={page} />
