---
import { getCollection } from "astro:content";
import PostDetailView from "@/components/pageViews/PostDetailView.astro";
import { getPostSlug } from "@/utils/getPostPaths";
import { getPostsForLocale } from "@/utils/i18nPosts";
import { getRelatedPosts } from "@/utils/getRelatedPosts";
import { DEFAULT_LOCALE } from "@/i18n";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  // 默认语言文章定义可访问的 slug 集合
  const defaultPosts = getPostsForLocale(posts, DEFAULT_LOCALE);

  return defaultPosts.map((post, index) => ({
    params: { slug: getPostSlug(post.id, post.filePath) },
    props: {
      post,
      prevPost: index > 0 ? defaultPosts[index - 1] : null,
      nextPost: index < defaultPosts.length - 1 ? defaultPosts[index + 1] : null,
      relatedPosts: getRelatedPosts(post, defaultPosts),
    },
  }));
}

const { post, prevPost, nextPost, relatedPosts } = Astro.props;
---

<PostDetailView
  post={post}
  prevPost={prevPost}
  nextPost={nextPost}
  relatedPosts={relatedPosts}
/>
